{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhotoHelper",
  "version": "0.2.0",
  "identifier": "com.photohelper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PhotoHelper",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
